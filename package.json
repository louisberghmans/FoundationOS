{
  "name": "foundation-os",
  "private": true,
  "version": "0.4.1-alpha",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "node server.mjs",
    "build": "tsc -b && vite build",
    "check:server": "node --check server.mjs && node --check src/server/app.mjs && node --check src/server/auth.mjs && node --check src/server/core.mjs && node --check src/server/database.mjs && node --check src/server/finance.mjs && node --check src/server/policy.mjs && node --check src/server/version.mjs",
    "lint": "eslint .",
    "test": "vitest run && node --test tests/*.test.mjs",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@primer/primitives": "^11.9.0",
    "@primer/react": "^38.32.0",
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.9.0"
}
